[{calc_modifier(score); floor_div(score + 10, 2)}]
[{hp_rolls; 8 4}]

Name: John Johnson
Level: [[level; 2]]
HP: [[hp; sum(hp_rolls) + con_mod * level]]

STR: [[str; 12]] | +[[str_mod; calc_modifier(str)]]
DEX: [[dex; 12]] | +[[dex_mod; calc_modifier(dex)]]
CON: [[con; 12]] | +[[con_mod; calc_modifier(con)]]
WIS: [[wis; 12]] | +[[wis_mod; calc_modifier(wis)]]
INT: [[int; 12]] | +[[int_mod; calc_modifier(int)]]
CHA: [[cha; 12]] | +[[cha_mod; calc_modifier(cha)]]